{
  "name": "ordolith-launcher",
  "version": "0.1.0",
  "description": "Open-source, cross-platform Minecraft: Java Edition launcher focused on transparency and user control.",
  "main": "./out/main/index.js",
  "author": "MethodRanger",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MethodRanger/Ordolith-Launcher.git"
  },
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "adm-zip": "^0.6.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "pidusage": "^4.0.1",
    "tar-stream": "^3.2.0",
    "unzipper": "^0.12.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.5",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.2",
    "png2icons": "^2.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
